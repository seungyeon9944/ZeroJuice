# =============================================
# ZeroJuice Environment Variables
# =============================================
# 이 파일을 복사하여 .env 파일로 저장하고 실제 값을 입력하세요.
# .env 파일은 Git에 커밋되지 않습니다.
# =============================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zerojuice
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_VALIDITY=3600000
JWT_REFRESH_VALIDITY=604800000

# MQTT
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=zerojuice-server
MQTT_USERNAME=
MQTT_PASSWORD=

# Firebase (FCM)
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json

# Server
SERVER_PORT=8080

# Logging
LOG_LEVEL=INFO
