<?xml version="1.0"?>
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode name="NavigateRecovery" number_of_retries="5">
      <Sequence name="NavigateToPose">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="SmacHybridReeds"/>
        <FollowPath path="{path}" controller_id="ParkController"/>
      </Sequence>
      <Sequence name="RecoveryActions">
        <DriveOnHeading dist_to_travel="0.3" speed="0.18" time_allowance="10.0"/>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>